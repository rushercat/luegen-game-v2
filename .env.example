# Copy this file to `.env` and fill in your Supabase credentials.
# The .env file should NOT be committed to git (already in .gitignore).
#
# Get these from Supabase: Project Settings -> API
#   SUPABASE_URL is the Project URL (e.g. https://abcdefg.supabase.co)
#   SUPABASE_SERVICE_KEY is the "service_role" secret key (NOT the anon key).
#     The service role key bypasses Row Level Security — keep it server-side only.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# The anon key is needed for verifying user JWTs and for the browser-side
# Supabase client (Google sign-in). It's safe to expose to the browser.
SUPABASE_ANON_KEY=

# Optional: change the listen port (default 3000)
# PORT=3000
